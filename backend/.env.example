# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/railyatra

# Cloud (MongoDB Atlas — required for Render / Vercel deployment):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/railyatra?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your Vercel frontend URL in production, e.g:
# CLIENT_ORIGIN=https://railyatra.vercel.app
CLIENT_ORIGIN=http://localhost:5173
